{
  "name": "movets.org",
  "version": "1.0.0",
  "description": "### 🧱 Requirements",
  "main": "index.js",
  "scripts": {
    "dev": "npx tailwindcss -i ./tailwind.css -o ./site/css/styles.css --watch",
    "build": "npx tailwindcss -i ./tailwind.css -o ./site/css/styles.css --minify",
    "build:deploy": "npm run build && node scripts/inject-env.js",
