# Cloudflare
cloudflare_api_token  = "your-cloudflare-api-token"     # Profile > API Tokens > Create Token
cloudflare_account_id = "your-cloudflare-account-id"     # Workers & Pages > right sidebar
workers_subdomain     = "your-subdomain"                 # Workers & Pages > Overview > Your subdomain (e.g. "bh-cloudflare-8d4")

# Domain
domain = "movets.org"

# Brevo
brevo_api_key = "your-brevo-api-key"                     # Brevo > Settings > SMTP & API > API Keys

# Turnstile (secret only — site key is auto-generated by Terraform)
turnstile_secret_key = "your-turnstile-secret-key"       # Cloudflare > Turnstile > your widget > Secret Key

# Analytics
cf_analytics_token = "your-analytics-token"              # Cloudflare > Web Analytics > your site > token

# GitHub (for Cloudflare Pages auto-deploy)
github_owner = "your-github-username"                    # e.g. "brandonhon"
github_repo  = "movets.org"                              # repository name
